    "test:watch": "vitest",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "fast-check": "^3.23.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
